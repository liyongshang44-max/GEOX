{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "device_observation_v1.schema.json",
  "title": "device_observation_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "schema_version",
    "tenant_id",
    "project_id",
    "group_id",
    "field_id",
    "device_id",
    "observed_at",
    "ingested_at",
    "metric_key",
    "metric_value",
    "metric_unit",
    "confidence",
    "quality_flags",
    "explanation_codes"
  ],
  "properties": {
    "type": { "const": "device_observation_v1" },
    "schema_version": { "const": "1.0.0" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "group_id": { "type": "string", "minLength": 1 },
    "field_id": { "type": "string", "minLength": 1 },
    "device_id": { "type": "string", "minLength": 1 },
    "observed_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "metric_key": { "type": "string", "minLength": 1 },
    "metric_value": { "type": "number" },
    "metric_unit": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["OK", "SUSPECT", "OUTLIER", "MISSING_CONTEXT", "CALIBRATION_DUE"]
      }
    },
    "explanation_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
