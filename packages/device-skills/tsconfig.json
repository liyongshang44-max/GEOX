{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "../..",
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "../../packages/contracts/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "../../packages/**/dist/**/*", "../../node_modules/**/*"]
}
