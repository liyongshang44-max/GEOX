{
  "name": "@geox/executor",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "runtime": "node dist/runtime_loop.js",
    "once": "node dist/run_once.js",
    "dispatch-once": "node dist/run_dispatch_once.js",
    "dispatch-mqtt-once": "node dist/run_mqtt_downlink_once.js",
    "device-sim-once": "node dist/run_mqtt_device_sim_once.js",
    "receipt-uplink-once": "node dist/run_mqtt_receipt_uplink_once.js",
    "dev:runtime": "pnpm run build && node dist/runtime_loop.js",
    "dev:once": "pnpm run build && node dist/run_once.js",
    "dev:dispatch-once": "pnpm run build && node dist/run_dispatch_once.js",
    "dev:dispatch-mqtt-once": "pnpm run build && node dist/run_mqtt_downlink_once.js",
    "dev:device-sim-once": "pnpm run build && node dist/run_mqtt_device_sim_once.js",
    "dev:receipt-uplink-once": "pnpm run build && node dist/run_mqtt_receipt_uplink_once.js"
  },
  "dependencies": {
    "@geox/contracts": "workspace:*",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "@types/node": "^20"
  }
}
