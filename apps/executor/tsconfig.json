{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "moduleDetection": "force",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "strict": false
  },
  "include": ["src/**/*.ts"]
}
