async function upsertDispatchIndexFromFacts(pool: Pool, tenant: TenantTriple, taskFact: ParsedFactRow, outboxFact: ParsedFactRow, dispatchFact?: ParsedFactRow | null): Promise<void> {
  const task = taskFact.record_json ?? {}; // Task snapshot.
  const outbox = outboxFact.record_json ?? {}; // Outbox snapshot.
  const act_task_id = String(outbox?.payload?.act_task_id ?? task?.payload?.act_task_id ?? "").trim(); // Projection key.
  if (!act_task_id) return; // Ignore malformed facts.
  await pool.query(
    `INSERT INTO ao_act_dispatch_index_v1 (
       tenant_id, project_id, group_id, act_task_id,
       outbox_fact_id, outbox_occurred_at, outbox_json,
       task_fact_id, task_occurred_at, task_json,
       latest_status, updated_at
     ) VALUES ($1,$2,$3,$4,$5,$6,$7::jsonb,$8,$9,$10::jsonb,'OPEN',NOW())
     ON CONFLICT (tenant_id, project_id, group_id, act_task_id)
     DO UPDATE SET
       outbox_fact_id = EXCLUDED.outbox_fact_id,
       outbox_occurred_at = EXCLUDED.outbox_occurred_at,
       outbox_json = EXCLUDED.outbox_json,
       task_fact_id = EXCLUDED.task_fact_id,
       task_occurred_at = EXCLUDED.task_occurred_at,
       task_json = EXCLUDED.task_json,
       latest_status = 'OPEN',
       updated_at = NOW()`,
    [tenant.tenant_id, tenant.project_id, tenant.group_id, act_task_id, outboxFact.fact_id, outboxFact.occurred_at, JSON.stringify(outbox), taskFact.fact_id, taskFact.occurred_at, JSON.stringify(task)]
  ); // Upsert dispatch projection.
  if (dispatchFact) {
    await pool.query(
      `UPDATE ao_act_task_index_v1
          SET dispatch_fact_id = $5,
              dispatch_occurred_at = $6,
              dispatch_json = $7::jsonb,
              latest_status = 'DISPATCHED',
              updated_at = NOW()
        WHERE tenant_id = $1 AND project_id = $2 AND group_id = $3 AND act_task_id = $4`,
      [tenant.tenant_id, tenant.project_id, tenant.group_id, act_task_id, dispatchFact.fact_id, dispatchFact.occurred_at, JSON.stringify(dispatchFact.record_json ?? {})]
    ); // Link dispatch to task projection.
  }
}

