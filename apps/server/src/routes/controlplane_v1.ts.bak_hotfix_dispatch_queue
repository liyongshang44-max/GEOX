async function upsertApprovalRequestIndex(pool: Pool, tenant: TenantTriple, requestFact: ParsedFactRow): Promise<void> {
  const request = requestFact.record_json ?? {}; // Stable request snapshot.
  const request_id = String(request?.payload?.request_id ?? "").trim(); // Projection key.
  if (!request_id) return; // Ignore malformed facts.
  await pool.query(
    `INSERT INTO approval_request_index_v1 (
       tenant_id, project_id, group_id, request_id,
       request_fact_id, request_occurred_at, request_json, status, updated_at
     ) VALUES ($1,$2,$3,$4,$5,$6,$7::jsonb,$8,NOW())
     ON CONFLICT (tenant_id, project_id, group_id, request_id)
     DO UPDATE SET
       request_fact_id = EXCLUDED.request_fact_id,
       request_occurred_at = EXCLUDED.request_occurred_at,
       request_json = EXCLUDED.request_json,
       status = CASE WHEN approval_request_index_v1.decision_fact_id IS NULL THEN EXCLUDED.status ELSE approval_request_index_v1.status END,
       updated_at = NOW()`,
    [tenant.tenant_id, tenant.project_id, tenant.group_id, request_id, requestFact.fact_id, requestFact.occurred_at, JSON.stringify(request), String(request?.payload?.status ?? "PENDING")]
  ); // Upsert request projection.
}

async function upsertApprovalDecisionIndex(pool: Pool, tenant: TenantTriple, decisionFact: ParsedFactRow): Promise<void> {
  const decision = decisionFact.record_json ?? {}; // Stable decision snapshot.
  const request_id = String(decision?.payload?.request_id ?? "").trim(); // Join key.
  if (!request_id) return; // Ignore malformed facts.
  await pool.query(
    `UPDATE approval_request_index_v1
        SET status = $5,
            decision_fact_id = $6,
            decision_occurred_at = $7,
            decision_json = $8::jsonb,
            act_task_id = $9,
            updated_at = NOW()
      WHERE tenant_id = $1 AND project_id = $2 AND group_id = $3 AND request_id = $4`,
    [tenant.tenant_id, tenant.project_id, tenant.group_id, request_id, String(decision?.payload?.decision ?? "PENDING"), decisionFact.fact_id, decisionFact.occurred_at, JSON.stringify(decision), decision?.payload?.act_task_id ?? null]
  ); // Upsert decision projection.
}

