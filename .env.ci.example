# GEOX CI/runtime acceptance defaults.
# Copy to .env.ci for local acceptance runs; do not commit real secrets.

GEOX_RUNTIME_ENV=ci
POSTGRES_USER=landos
POSTGRES_PASSWORD=landos_pwd
POSTGRES_DB=landos
GEOX_MCFT_MIGRATOR_PASSWORD=ci-mcft-migrator-password
GEOX_RUNTIME_DATABASE_PASSWORD=ci-runtime-database-password
GEOX_DEPLOYMENT_SUBJECT_COMMIT=0000000000000000000000000000000000000000
DATABASE_URL=postgres://geox_runtime_v1:ci-runtime-database-password@127.0.0.1:5433/landos
