# GEOX runtime env template (copy to .env before docker compose up)
# Required by executor/jobs/telemetry-ingest in compose profiles.
# Source options:
# 1) Secret manager / CI secret injection
# 2) Local auth SSOT file: config/auth/ao_act_tokens_v0.json
GEOX_AO_ACT_TOKEN=

# Optional identity defaults used by runtime services.
GEOX_TENANT_ID=tenantA
GEOX_PROJECT_ID=projectA
GEOX_GROUP_ID=groupA
POLL_INTERVAL_MS=3000
