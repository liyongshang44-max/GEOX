# GEOX local development/test only.
# Do not use this file for controlled pilot or production deployments.

GEOX_RUNTIME_ENV=development
GEOX_TOKENS_JSON=
GEOX_ALLOWED_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
GEOX_EXECUTION_DEFAULT_DISABLED=1
GEOX_DEVTOOLS_ENABLED=0

# Local fallback secrets are intentionally weak and accepted only outside pilot/production.
POSTGRES_USER=landos
POSTGRES_PASSWORD=landos_pwd
POSTGRES_DB=landos
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MQTT_AUTH_REQUIRED=0
MQTT_USERNAME=local_mqtt_user
MQTT_PASSWORD=local_mqtt_password
APP_SECRET=local-dev-only-secret
PUBLIC_BASE_URL=http://localhost:3001
