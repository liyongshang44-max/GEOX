# GEOX controlled pilot / production runtime baseline.
# Replace every value before deployment; placeholders must not pass runtime security checks.

GEOX_RUNTIME_ENV=pilot
GEOX_TOKENS_FILE=/run/secrets/geox_tokens.json
CORS_ORIGINS=https://pilot.example.geox.invalid
GEOX_ALLOWED_ORIGINS=https://pilot.example.geox.invalid
APP_SECRET=<strong-random-32-byte-minimum>
GEOX_APP_SECRET=<strong-random-32-byte-minimum>
PUBLIC_BASE_URL=https://pilot.example.geox.invalid
GEOX_PUBLIC_BASE_URL=https://pilot.example.geox.invalid

POSTGRES_USER=geox
POSTGRES_PASSWORD=<strong-random-postgres-password>
POSTGRES_DB=geox
MINIO_ROOT_USER=geox-minio
MINIO_ROOT_PASSWORD=<strong-random-minio-password>

MQTT_AUTH_REQUIRED=1
GEOX_MQTT_AUTH_REQUIRED=1
MQTT_USERNAME=geox-mqtt
MQTT_PASSWORD=<strong-random-mqtt-password>
GEOX_MQTT_USERNAME=geox-mqtt
GEOX_MQTT_PASSWORD=<strong-random-mqtt-password>

GEOX_EXECUTION_DEFAULT_DISABLED=1
GEOX_EXECUTION_ENABLE_EXPLICITLY=0
GEOX_EXECUTION_ENABLE_REASON=
GEOX_DEVTOOLS_ENABLED=0
