GEOX_RUNTIME_ENV=production
GEOX_TOKENS_FILE=<set-via-docker-secret>
GEOX_ALLOWED_ORIGINS=<set-via-secret-manager>
POSTGRES_PASSWORD=<set-via-secret-manager>
MINIO_ROOT_PASSWORD=<set-via-secret-manager>
MQTT_AUTH_REQUIRED=1
MQTT_PASSWORD=<set-via-secret-manager>
GEOX_EXECUTION_DEFAULT_DISABLED=1
GEOX_APP_SECRET=<set-via-secret-manager>
GEOX_PUBLIC_BASE_URL=<set-via-secret-manager>
