    {
      "object_type": "twin_state_transition_v1",
      "record_class": "CANONICAL_TWIN_HISTORY",
      "history_class": "CANONICAL_TWIN_HISTORY",
      "lineage_member": true,
      "envelope_profile": "LINEAGE",
