    {
      "object_type": "twin_forecast_run_v1",
      "record_class": "CANONICAL_TWIN_HISTORY",
      "history_class": "CANONICAL_TWIN_HISTORY",
      "lineage_member": true,
      "envelope_profile": "LINEAGE",
      "atomic_aggregate": "one aggregate containing status and all points",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["A_STATE_TICK_COMMIT"],
      "required_refs": ["source_posterior_ref", "runtime_config_ref"],
      "optional_refs": ["weather_refs"],
      "status_contract": {
        "COMPLETED": {
          "points_count": 72,
          "horizons": "1..72",
          "reason_codes_required": false,
          "tick_status": "COMPLETED",
          "checkpoint_advances": true,
          "latest_forecast_result_advances": true,
          "latest_successful_forecast_advances": true,
          "scenario_eligible": true
        },
        "BLOCKED": {
          "points_count": 0,
          "reason_codes_required": true,
          "reason_codes_owner": "twin_forecast_run_v1",
          "tick_status": "COMPLETED_WITH_LIMITATIONS",
          "checkpoint_advances": true,
          "latest_forecast_result_advances": true,
          "latest_successful_forecast_advances": false,
          "scenario_eligible": false
        },
        "FAILED": {"permitted": false, "replacement_object": "twin_forecast_failure_v1"}
      }
    },
    {
      "object_type": "twin_forecast_failure_v1",
      "record_class": "OPERATIONAL_AUDIT",
      "history_class": "OPERATIONAL_AUDIT",
      "lineage_member": false,
      "envelope_profile": "NON_LINEAGE_CONTEXT",
      "atomic_aggregate": "single failed forecast diagnostic",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["F_OPERATIONAL_ATTEMPT_HEALTH"],
      "required_refs": ["attempt_ref", "reason_codes"],
      "optional_refs": ["source_posterior_ref", "context_lineage_ref", "context_revision_ref", "runtime_config_ref"],
      "status_contract": {
        "FAILED": {
          "points_field": "forbidden",
          "checkpoint_advances": false,
          "terminal_tick_created": false,
          "active_lineage_member": false
        }
      }
    },
    {
