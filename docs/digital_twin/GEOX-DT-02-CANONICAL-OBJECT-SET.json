      "transaction_families": ["D_MODEL_GOVERNANCE_STEP_COMMIT"],
      "required_refs": ["soil_root_zone_config_refs", "model_component_refs"],
      "optional_refs": []
    },
    {
      "object_type": "twin_runtime_checkpoint_v1",
      "record_class": "CANONICAL_TWIN_HISTORY",
      "history_class": "CANONICAL_TWIN_HISTORY",
      "lineage_member": true,
      "envelope_profile": "LINEAGE",
