{
  "schema_version": "geox_dt02_canonical_object_set_v3",
  "phase": "DT-02",
  "status": "FROZEN_WITH_AMENDMENTS_PENDING_ACCEPTANCE",
  "amendment_refs": [
    "docs/digital_twin/GEOX-DT-02-ARCHITECTURE-AMENDMENT-01.md",
    "docs/digital_twin/GEOX-DT-02-ARCHITECTURE-AMENDMENT-02.md"
  ],
  "storage_binding": {
    "canonical_store": "Postgres facts append-only store",
    "fact_envelope": {
      "fact_id": "persistence-assigned storage identity",
      "occurred_at": "logical event time selected by object contract",
      "source": "authorized writer class",
      "record_json.type": "object_type",
      "record_json.payload": "semantic object envelope"
    },
    "identity_separation": [
      "object_id is semantic and deterministic",
      "fact_id is storage-envelope identity",
      "fact_id is excluded from object_id and determinism_hash",
      "persistence returns object_id-to-fact_id mapping"
    ]
  },
  "envelope_contracts": {
    "base_object_envelope": {
      "required_fields": [
        "object_id",
        "object_type",
        "schema_version",
        "tenant_id",
        "project_id",
        "group_id",
        "field_id",
        "season_id",
        "zone_id",
        "logical_time",
        "as_of",
        "source_refs",
        "evidence_refs",
        "runtime_config_ref",
        "runtime_config_hash",
        "idempotency_key",
        "determinism_hash",
        "limitations",
        "created_at"
      ],
      "nullable_by_contract": [
        "group_id",
        "season_id",
        "zone_id",
        "runtime_config_ref",
        "runtime_config_hash"
      ],
      "rules": [
        "all timestamps are UTC ISO-8601",
        "all units are explicit",
        "unknown and missing values are explicit",
        "created_at is excluded from determinism_hash",
        "fact_id is not a semantic-envelope field"
      ]
    },
    "lineage_envelope": {
      "applies_when": {"lineage_member": true},
      "required_fields": ["lineage_id", "revision_id"],
      "optional_fields": ["supersedes_ref", "original_tick_ref", "revision_run_ref"],
      "conditional_rules": {
        "INITIAL": {
          "revision_id_required": true,
          "revision_run_ref": null,
          "revision_run_object_required": false
        },
        "REVISION_REPLAY": {
          "revision_id_required": true,
          "revision_run_ref_required": true
        }
      },
      "forbidden_rules": ["lineage_id or revision_id missing"]
    },
    "non_lineage_context_envelope": {
      "applies_when": {"lineage_member": false},
      "required_fields": [],
      "optional_fields": [
        "context_lineage_ref",
        "context_revision_ref",
        "supersedes_ref",
        "original_tick_ref"
      ],
      "rules": [
        "lineage_id and revision_id are not required",
        "record may exist before bootstrap, active lineage, config, or checkpoint"
      ]
    }
  },
  "objects": [
    {
