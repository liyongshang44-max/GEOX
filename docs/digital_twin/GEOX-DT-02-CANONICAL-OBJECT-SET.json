      "envelope_profile": "NON_LINEAGE_CONTEXT",
      "atomic_aggregate": "revision declaration, progress, or terminal event",
      "writer": "Revision Service",
      "transaction_families": ["E_REVISION_LINEAGE_STEP_COMMIT"],
      "required_refs": ["revision_run_id", "candidate_lineage_ref"],
      "optional_refs": ["parent_lineage_ref", "late_evidence_refs", "context_lineage_ref"],
      "status_contract": {
        "DECLARED": {},
        "RUNNING": {},
        "FAILED": {"promotion_eligible": false},
        "COMPLETED": {"promotion_eligible": "requires separate chain validation"}
      },
      "field_contract": {"INITIAL_revision_creates_object": false}
    },
    {
      "object_type": "twin_lineage_promotion_v1",
      "record_class": "CANONICAL_LINEAGE_HISTORY",
