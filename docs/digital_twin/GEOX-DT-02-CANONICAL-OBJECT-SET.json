    {
      "object_type": "twin_runtime_health_v1",
      "record_class": "OPERATIONAL_AUDIT",
      "history_class": "OPERATIONAL_AUDIT",
      "lineage_member": false,
      "envelope_profile": "NON_LINEAGE_CONTEXT",
      "atomic_aggregate": "runtime-operation snapshot",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["A_STATE_TICK_COMMIT", "F_OPERATIONAL_ATTEMPT_HEALTH"],
      "required_refs": [],
      "optional_refs": ["attempt_ref", "context_lineage_ref", "context_revision_ref", "checkpoint_ref", "runtime_config_ref"]
    },
    {
      "object_type": "twin_runtime_lineage_v1",
      "record_class": "CANONICAL_LINEAGE_HISTORY",
      "history_class": "CANONICAL_LINEAGE_HISTORY",
      "lineage_member": false,
      "envelope_profile": "NON_LINEAGE_CONTEXT",
      "atomic_aggregate": "initial lineage declaration or revision candidate lineage declaration",
      "writer": "conditional by lineage_kind",
      "transaction_families": ["A_STATE_TICK_COMMIT", "E_REVISION_LINEAGE_STEP_COMMIT"],
      "required_refs": [],
      "optional_refs": [
        "revision_run_ref",
        "parent_lineage_ref",
        "bootstrap_runtime_config_ref",
        "bootstrap_reality_binding_ref",
        "initial_revision_id"
      ],
      "field_contract": {
        "lineage_kind": ["INITIAL", "REVISION_CANDIDATE"],
        "INITIAL": {
          "writer": "Runtime Orchestrator",
          "transaction_family": "A_STATE_TICK_COMMIT",
          "operation_variant": "A0_BOOTSTRAP_STATE_COMMIT",
          "parent_lineage_ref": null,
          "revision_run_ref": null,
          "required_refs": ["bootstrap_runtime_config_ref", "bootstrap_reality_binding_ref", "initial_revision_id"],
          "activation_authority_kind": "INITIAL_LINEAGE_DECLARATION"
        },
        "REVISION_CANDIDATE": {
          "writer": "Revision Service",
          "transaction_family": "E_REVISION_LINEAGE_STEP_COMMIT",
          "required_refs": ["revision_run_ref", "parent_lineage_ref"],
          "forbidden_refs": ["bootstrap_runtime_config_ref", "bootstrap_reality_binding_ref"]
        }
      }
    },
    {
      "object_type": "twin_revision_run_v1",
      "record_class": "CANONICAL_LINEAGE_HISTORY",
