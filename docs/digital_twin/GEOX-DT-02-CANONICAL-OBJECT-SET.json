      "optional_refs": [],
      "status_contract": {
        "COMPLETED": {"checkpoint_advances": true, "forecast_status": "COMPLETED"},
        "COMPLETED_WITH_LIMITATIONS": {"checkpoint_advances": true, "forecast_status": "BLOCKED"}
      }
    },
    {
      "object_type": "twin_evidence_window_v1",
