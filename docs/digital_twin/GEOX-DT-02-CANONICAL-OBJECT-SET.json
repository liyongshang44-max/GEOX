      "required_refs": ["assimilation_update_ref", "posterior_state_ref", "runtime_config_ref"],
      "optional_refs": ["previous_posterior_ref"],
      "field_contract": {
        "transition_kind": ["BOOTSTRAP", "CONTINUATION", "REVISION_REPLAY"],
        "BOOTSTRAP": {
          "previous_posterior_ref": null,
          "bootstrap_prior_required": true,
          "bootstrap_prior_ref_forbidden": true,
          "process_model_status": "NOT_APPLIED_BOOTSTRAP"
        },
        "CONTINUATION": {
          "previous_posterior_ref_required": true,
          "bootstrap_prior_forbidden": true,
          "bootstrap_prior_ref_forbidden": true
        },
        "REVISION_REPLAY": {
          "previous_posterior_ref_required": true,
          "bootstrap_prior_forbidden": true,
          "bootstrap_prior_ref_forbidden": true
        },
        "embedded_bootstrap_prior_required_fields": [
          "prior_kind",
          "mean",
          "variance",
          "stddev",
          "derivation_rule_id",
          "source_runtime_config_ref",
          "source_soil_hydraulic_config_ref"
        ],
        "embedded_bootstrap_prior_canonical_object": false
      }
    },
    {
      "object_type": "twin_assimilation_update_v1",
      "record_class": "CANONICAL_TWIN_HISTORY",
      "history_class": "CANONICAL_TWIN_HISTORY",
      "lineage_member": true,
      "envelope_profile": "LINEAGE",
      "atomic_aggregate": "member of atomic State Tick record set",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["A_STATE_TICK_COMMIT"],
      "required_refs": ["state_transition_ref", "posterior_state_ref", "runtime_config_ref"],
      "optional_refs": []
    },
    {
      "object_type": "twin_state_estimate_v1",
      "record_class": "CANONICAL_TWIN_HISTORY",
      "history_class": "CANONICAL_TWIN_HISTORY",
      "lineage_member": true,
      "envelope_profile": "LINEAGE",
      "atomic_aggregate": "posterior member of State Tick record set",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["A_STATE_TICK_COMMIT"],
      "required_refs": ["prior_transition_ref", "assimilation_update_ref", "runtime_config_ref"],
      "optional_refs": [],
      "field_contract": {
        "confidence": {
          "status": "NOT_ESTABLISHED",
          "reason_code": "NO_CALIBRATED_CONFIDENCE_MODEL",
