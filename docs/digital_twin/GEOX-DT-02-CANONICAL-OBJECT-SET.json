      "envelope_profile": "LINEAGE",
      "atomic_aggregate": "terminal tick inside State Tick record set",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["A_STATE_TICK_COMMIT"],
      "required_refs": [
        "evidence_window_ref",
        "state_transition_ref",
        "assimilation_update_ref",
        "posterior_state_ref",
        "forecast_result_ref",
        "checkpoint_ref"
