    }
  ],
  "noncanonical_operational_tables": [
    {"logical_name": "twin_runtime_lease_v1", "purpose": "writer lease with owner, fencing token, expiry, heartbeat", "mutable": true},
    {"logical_name": "twin_runtime_attempt_latest_v1", "purpose": "current attempt state", "mutable": true},
    {"logical_name": "twin_runtime_worker_heartbeat_v1", "purpose": "worker liveness and diagnostics", "mutable": true},
    {"logical_name": "temporary_compute_attempt_state", "purpose": "ephemeral retry diagnostics", "mutable": true},
    {"logical_name": "twin_object_idempotency_index_v1", "purpose": "aggregate and object idempotency guard with independently computed semantic hashes", "mutable": true}
  ],
  "mutable_rebuildable_projections": [
    "twin_state_latest_index_v1",
    "twin_state_history_projection_v1",
    "twin_forecast_run_index_v1",
    "twin_forecast_point_index_v1",
    "twin_forecast_result_latest_index_v1",
    "twin_forecast_success_latest_index_v1",
    "twin_scenario_set_index_v1",
    "twin_scenario_point_index_v1",
    "twin_scenario_latest_index_v1",
    "twin_forecast_residual_index_v1",
    "twin_runtime_checkpoint_latest_index_v1",
    "twin_runtime_health_latest_index_v1",
    "twin_active_lineage_index_v1",
    "twin_active_config_index_v1"
  ],
  "active_lineage_index_contract": {
    "required_audit_fields": ["activation_authority_kind", "activation_authority_ref", "expected_previous_active_lineage"],
    "INITIAL": {
      "activation_authority_kind": "INITIAL_LINEAGE_DECLARATION",
      "authority_object_type": "twin_runtime_lineage_v1",
      "expected_previous_active_lineage": null
    },
    "REVISION": {
      "activation_authority_kind": "LINEAGE_PROMOTION",
      "authority_object_type": "twin_lineage_promotion_v1"
    }
  },
  "forbidden": [
    "dual canonical storage",
    "canonical UPDATE",
    "projection as historical truth",
    "operational lease as Twin State",
    "client-supplied posterior, Forecast, or Scenario result",
    "natural-language transaction family expression",
    "bootstrap_prior_ref",
    "initial lineage promotion record",
    "INITIAL revision requiring twin_revision_run_v1"
  ],
  "object_contract_rules": [
    "record_class is authoritative; history_class is compatibility alias and must equal record_class",
    "every object declares lineage_member and transaction_families",
    "lineage_member=true uses LINEAGE envelope",
    "lineage_member=false uses NON_LINEAGE_CONTEXT envelope",
    "every listed transaction family must cover the object in canonical_appends or operation_variants",
    "A0 lineage members share one deterministic initial lineage_id and revision_id",
    "INITIAL revision_id does not imply a revision-run object"
  ]
}
