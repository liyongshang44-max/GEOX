      "envelope_profile": "NON_LINEAGE_CONTEXT",
      "atomic_aggregate": "single attempt event",
      "writer": "Runtime Orchestrator",
      "transaction_families": ["F_OPERATIONAL_ATTEMPT_HEALTH"],
      "required_refs": ["attempt_id"],
      "optional_refs": ["context_lineage_ref", "context_revision_ref", "checkpoint_ref", "runtime_config_ref"]
