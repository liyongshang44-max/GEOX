        "trusted_execution_source_rule": "at least one of receipt_ref or as_executed_ref",
        "acceptance_ref_required": false,
        "task_ref_rule": "required only when origin_kind = AO_ACT",
        "eligibility_basis": [
          "actual_amount",
          "executed_at",
          "spatial_coverage",
          "source_identity",
          "source_quality",
          "limitations"
        ]
      }
    },
