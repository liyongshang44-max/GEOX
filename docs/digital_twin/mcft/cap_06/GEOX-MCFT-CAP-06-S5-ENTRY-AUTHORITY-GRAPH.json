{
  "schema_version": "geox_mcft_cap_06_s5_entry_authority_graph_v1",
  "graph_id": "MCFT-CAP-06.S5-EXACT-FORECAST-OBSERVATION-AUTHORITY-GRAPH-V1",
  "capability_line_id": "MCFT-CAP-06",
  "status": "FROZEN",
  "root_node_id": "residual",
  "resolution_policy": {
    "mode": "EXACT_REF_HASH_ONLY",
    "snapshot": "ONE_REPEATABLE_READ_READ_ONLY_TRANSACTION",
    "forbidden_surfaces": [
      "LATEST",
      "TIME_RANGE_SEARCH",
      "SCOPE_RANGE_SEARCH",
      "ALTERNATIVE_GRAPH_TRAVERSAL",
      "RAW_OBSERVATION_SIDE_LOOKUP"
    ],
    "canonical_identity_assignment": false,
    "canonical_write_count": 0
  },
  "nodes": [
    {"node_id":"residual","object_type":"twin_forecast_residual_v1","authority_role":"CASE_ROOT","identity":"object_id+determinism_hash"},
    {"node_id":"forecast","object_type":"twin_forecast_run_v1","authority_role":"SOURCE_FORECAST","identity":"object_id+determinism_hash"},
    {"node_id":"forecast_point","object_type":"FORECAST_POINT_MEMBER","authority_role":"PREDICTION_MEMBER","identity":"forecast_point_ref+forecast_point_hash"},
    {"node_id":"forecast_config","object_type":"twin_runtime_config_v1","authority_role":"FORECAST_EXECUTION_CONFIG","identity":"object_id+determinism_hash"},
    {"node_id":"source_posterior","object_type":"twin_state_estimate_v1","authority_role":"FORECAST_SOURCE_POSTERIOR","identity":"object_id+determinism_hash"},
    {"node_id":"forecast_evidence_window","object_type":"twin_evidence_window_v1","authority_role":"FORECAST_INFORMATION_CUTOFF","identity":"object_id+canonical_envelope_hash"},
    {"node_id":"residual_config","object_type":"twin_runtime_config_v1","authority_role":"RESIDUAL_AND_ASSIMILATION_EXECUTION_CONFIG","identity":"object_id+determinism_hash"},
    {"node_id":"assimilation","object_type":"twin_assimilation_update_v1","authority_role":"OBSERVATION_ASSIMILATION","identity":"object_id+determinism_hash"},
    {"node_id":"observation_posterior","object_type":"twin_state_estimate_v1","authority_role":"OBSERVATION_POSTERIOR","identity":"object_id+determinism_hash"},
    {"node_id":"observation_evidence_window","object_type":"twin_evidence_window_v1","authority_role":"OBSERVATION_SELECTION_AUTHORITY","identity":"object_id+canonical_envelope_hash"},
    {"node_id":"selected_observation","object_type":"EMBEDDED_CANONICAL_OBSERVATION_SNAPSHOT","authority_role":"ACTUAL_OBSERVATION","identity":"source_record_id+source_record_hash"}
  ],
  "edges": [
    {"from":"residual","to":"forecast","source_fields":["payload.forecast_run_ref","payload.forecast_run_hash"],"cardinality":"EXACTLY_ONE"},
    {"from":"residual","to":"forecast_point","source_fields":["payload.forecast_point_ref","payload.forecast_point_hash","payload.forecast_target_time"],"resolved_within":"forecast.payload.points","cardinality":"EXACTLY_ONE"},
    {"from":"forecast","to":"forecast_config","source_fields":["payload.runtime_config_ref","payload.runtime_config_hash"],"cardinality":"EXACTLY_ONE"},
    {"from":"forecast","to":"source_posterior","source_fields":["payload.source_posterior_ref","payload.source_posterior_hash"],"cardinality":"EXACTLY_ONE"},
    {"from":"source_posterior","to":"forecast_evidence_window","source_fields":["payload.evidence_window_ref"],"cardinality":"EXACTLY_ONE","note":"No separate source hash field exists; the resolved canonical envelope and final assembly hash carry the hash authority."},
    {"from":"residual","to":"residual_config","source_fields":["payload.runtime_config_ref","payload.runtime_config_hash"],"cardinality":"EXACTLY_ONE"},
    {"from":"residual","to":"assimilation","source_fields":["payload.assimilation_update_ref","payload.assimilation_update_hash"],"cardinality":"EXACTLY_ONE"},
    {"from":"assimilation","to":"observation_posterior","source_fields":["payload.posterior_state_ref"],"cardinality":"EXACTLY_ONE"},
    {"from":"observation_posterior","to":"observation_evidence_window","source_fields":["payload.evidence_window_ref"],"cardinality":"EXACTLY_ONE"},
    {"from":"observation_evidence_window","to":"selected_observation","source_fields":["payload.observation_selection.selected_observation_ref","payload.observation_selection.selected_observation|candidates"],"required_cross_pins":["residual.payload.actual_observation_ref","residual.payload.actual_observation_hash"],"cardinality":"EXACTLY_ONE"}
  ],
  "frozen_paths": [
    ["residual","forecast","forecast_config"],
    ["residual","forecast","source_posterior","forecast_evidence_window"],
    ["residual","residual_config"],
    ["residual","assimilation","observation_posterior","observation_evidence_window","selected_observation"]
  ],
  "cross_authority_invariants": [
    "FORECAST_CONFIG_AND_RESIDUAL_CONFIG_ARE_DISTINCT_AUTHORITIES_AND_MUST_NOT_BE_CONFLATED",
    "SOURCE_AND_RESIDUAL_EXECUTION_VIEWS_MUST_SHARE_REALITY_BINDING_AND_GEOMETRY",
    "FORECAST_METHOD_AND_FORCING_POLICY_MUST_MATCH_FORECAST_CONFIG",
    "OBSERVATION_OPERATOR_AND_NUMERIC_POLICY_MUST_MATCH_RESIDUAL_CONFIG_AND_ASSIMILATION",
    "LINEAGE_REVISION_AND_SCOPE_MUST_MATCH_ACROSS_ALL_CANONICAL_NODES",
    "SELECTED_OBSERVATION_IDENTITY_MUST_MATCH_RESIDUAL_ACTUAL_OBSERVATION_PINS"
  ],
  "dual_time_invariants": [
    "forecast_evidence_window.as_of <= forecast.as_of",
    "forecast.as_of < selected_observation.available_to_runtime_at",
    "forecast.payload.issued_at < selected_observation.available_to_runtime_at",
    "selected_observation.available_to_runtime_at <= observation_evidence_window.as_of",
    "observation_evidence_window.as_of == selected_observation.observed_at",
    "assimilation.logical_time == selected_observation.observed_at",
    "observation_posterior.logical_time == selected_observation.observed_at"
  ],
  "single_runtime_authority": {
    "graph_assembler": "PostgresResolvedForecastObservationCaseAssemblerV1",
    "read_model": "ResolvedForecastObservationCaseV1",
    "s2_case_builder": "buildCap06CaseWindowV1",
    "alternative_s5_or_s6_graph_authority_allowed": false
  }
}
