  "record_status": "FROZEN_S0_CONTRACT_CANDIDATE",
  "business_schema_structure_digest": {
    "include": [
      "relations",
      "columns",
      "types",
      "nullability",
      "defaults",
      "constraints",
      "indexes",
      "function_definitions",
      "trigger_definitions"
