    "direct_grant_inventory_only": false,
    "canonical_order": "GRANTEE_OBJECT_TYPE_SCHEMA_OBJECT_PRIVILEGE"
  },
  "required_equalities": [
    "BUSINESS_SCHEMA_STRUCTURE_BEFORE_EQUALS_AFTER",
    "ACTUAL_EFFECTIVE_GRAPH_EQUALS_WRITER_AUTHORITY",
    "CANONICAL_RELATION_COUNTS_BEFORE_EQUALS_AFTER"
  ],
  "unexpected_privilege_behavior": "FAIL_CLOSED"
}
