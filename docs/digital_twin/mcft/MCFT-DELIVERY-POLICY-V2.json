{
  "schema_version": "geox_mcft_delivery_policy_v2",
  "policy_id": "MCFT-DELIVERY-POLICY-V2",
  "record_status": "CONDITIONAL_EFFECTIVE_AUTHORITY",
  "committed_state": "FINAL_CANDIDATE",
  "effective_condition": "PRESENT_ON_DEFAULT_BRANCH_AND_PUSH_MAIN_POLICY_SELFTEST_PASS",
  "postmerge_ssot_writeback_allowed": false,
  "scope": "ALL_MCFT_CAPABILITY_LINES",
  "policy_kind": "REPOSITORY_WIDE_DELIVERY_PROCESS_POLICY",
  "supersedes": "docs/digital_twin/mcft/MCFT-DELIVERY-POLICY-V1.json",
  "capability_slice": false,
  "runtime_authority": false,
  "canonical_object_authority": false,
  "successor_capability_authority": false,
  "goals": [
    "REALTIME_CURRENT_PR_DELIVERY_ENFORCEMENT",
    "GENERIC_CANDIDATE_DECLARATION_INTEGRITY",
    "MERGE_REF_EXACT_TREE_EQUIVALENCE",
    "CURRENT_MAIN_BASE_STABILITY",
    "NO_CI_CODE_TRANSPORT",
    "NO_PROOF_ONLY_PR"
  ],
  "gap_classification": {
    "allowed_classes": [
      "IMPLEMENTATION_DEFECT",
      "TASKBOOK_DESIGN_DEFECT"
    ],
    "forbidden_mode": "FROZEN_TASKBOOK_PLUS_AD_HOC_PREREQUISITE_AND_CONTINUED_EXECUTION",
    "implementation_defect": {
      "correct_inside_current_slice": true,
      "task_order_change_allowed": false,
      "new_prerequisite_allowed": false
    },
    "taskbook_design_defect": {
      "pause_execution_required": true,
      "version_increment_required": true,
      "resolved_manifest_regeneration_required": true,
      "full_chain_impact_analysis_required": true,
      "refreeze_required": true
    }
  },
  "candidate_declaration": {
    "schema_version": "geox_mcft_candidate_declaration_v2",
    "marker": "MCFT_CANDIDATE_DECLARATION_V2",
    "applies_to": "ANY_MCFT_CAPABILITY_LINE_OR_SLICE",
    "required_fields": [
      "capability_line",
      "slice_id",
      "status_file",
      "candidate_field",
      "candidate_value",
      "focused_workflow",
      "standard_workflow",
      "semantic_snapshot_files",
      "semantic_snapshot_blobs",
      "candidate_head",
      "base_head"
    ],
    "candidate_transition_detection": {
      "path_scope_regex": "^docs/digital_twin/mcft/cap_[0-9]+/.*(?:STATUS|AUTHORITY).*\\.json$",
      "boolean_key_regex": "candidate",
      "candidate_status_values": [
        "CANDIDATE_IMPLEMENTED_NOT_EFFECTIVE",
        "IMPLEMENTATION_CANDIDATE",
        "REPAIR_CANDIDATE",
        "FINAL_CANDIDATE_AWAITING_EXACT_MERGE_SHA_ATTESTATION"
      ],
      "undeclared_transition_effect": "CANDIDATE_INVALIDATED"
    },
    "required_conditions": [
      "DECLARED_CANDIDATE_HEAD_EQUALS_CURRENT_PR_HEAD",
      "DECLARED_BASE_HEAD_EQUALS_CURRENT_PR_BASE",
      "STATUS_FIELD_EQUALS_DECLARED_VALUE",
      "SEMANTIC_SNAPSHOT_PATH_BLOB_PAIRS_MATCH_CURRENT_HEAD",
      "FOCUSED_WORKFLOW_PASS_ON_EXACT_HEAD",
      "STANDARD_WORKFLOW_PASS_ON_EXACT_HEAD",
      "PR_HEAD_STABLE_AFTER_WORKFLOW_PROOF"
    ],
    "failure_effect": "CANDIDATE_INVALIDATED"
  },
  "release_lane": {
    "lane_id": "MCFT-RELEASE-LANE-V1",
    "mode": "MERGE_REF_EXACT_TREE_GATE",
    "global_concurrency_group": "mcft-release-lane-main",
    "required_conditions": [
      "PR_NOT_DRAFT",
      "DECLARATION_V2_VALID",
      "CURRENT_MAIN_HEAD_EQUALS_PR_BASE_HEAD",
      "TEST_MERGE_PARENTS_BIND_CURRENT_BASE_AND_CANDIDATE_HEAD",
      "TEST_MERGE_TREE_EQUALS_CANDIDATE_HEAD_TREE",
      "PR_HEAD_STABLE_AT_LANE_COMPLETION"
    ],
    "base_drift_effect": "CANDIDATE_INVALIDATED_REBASE_OR_RECONSTRUCT_REQUIRED",
    "tree_drift_effect": "CANDIDATE_INVALIDATED",
    "normal_merge_method": "MERGE_COMMIT_OR_MERGE_QUEUE_WITH_TREE_EQUIVALENCE",
    "branch_transport_allowed": false,
    "validation_carrier_pr_allowed": false,
    "proof_only_pr_allowed": false
  },
  "workflow_security": {
    "pull_request_target_executes_default_branch_policy_only": true,
    "untrusted_pr_code_execution_under_pull_request_target": false,
    "repository_permissions": [
      "contents:read",
      "actions:read",
      "pull-requests:read"
    ],
    "repository_write_permission": false
  },
  "historical_policy": {
    "v1_status": "HISTORICAL_SUPERSEDED",
    "v1_candidate_rule_scope": "MCFT_CAP_06_S9_ONLY",
    "v1_realtime_enforcement": false,
    "v1_workflows_manual_only": true
  },
  "enforcement": {
    "policy_contract_workflow": ".github/workflows/mcft-delivery-policy-v2.yml",
    "candidate_integrity_workflow": ".github/workflows/mcft-candidate-declaration-integrity-v2.yml",
    "release_lane_workflow": ".github/workflows/mcft-release-lane-v1.yml",
    "policy_gate": "scripts/governance_acceptance/ACCEPTANCE_MCFT_DELIVERY_POLICY_V2.cjs",
    "candidate_gate": "scripts/governance_acceptance/ACCEPTANCE_MCFT_CANDIDATE_DECLARATION_INTEGRITY_V2.cjs",
    "release_lane_gate": "scripts/governance_acceptance/ACCEPTANCE_MCFT_RELEASE_LANE_V1.cjs"
  },
  "nonclaims": [
    "NOT_A_RUNTIME_CAPABILITY",
    "NOT_A_CAPABILITY_PREREQUISITE_SLICE",
    "DOES_NOT_AUTHORIZE_MCFT_CAP_07",
    "DOES_NOT_ENABLE_GITHUB_REPOSITORY_RULESET_BY_ITSELF"
  ]
}
