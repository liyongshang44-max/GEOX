{
  "schema": "executor_adapter_capability_manifest_v1",
  "version": "1.0.0",
  "phase": "P2 Real Adapter Integration",
  "task": "P2-02 Adapter Capability Manifest and Registry Audit",
  "boundary": {
    "no_live_device_integration": true,
    "no_broker_connection_attempted_by_manifest": true,
    "no_production_credential": true,
    "no_new_route": true,
    "no_db_migration": true,
    "no_ui": true,
    "no_scheduler": true,
    "no_priority_logic": true,
    "no_autonomous_execution": true,
    "no_automatic_recommendation": true,
    "no_automatic_approval": true,
    "no_automatic_ao_act_task_creation": true,
    "no_automatic_receipt_creation": true,
    "no_automatic_acceptance_creation": true,
    "no_automatic_roi_creation": true,
    "no_automatic_field_memory_creation": true,
    "no_model_update": true
  },
  "registry": {
    "source_file": "apps/executor/src/adapters/registry.ts",
    "expected_adapter_types": [
      "irrigation_real",
      "irrigation_simulator",
      "mqtt",
      "irrigation_http_v1"
    ],
    "expected_factories": [
      "createIrrigationRealAdapter",
      "createIrrigationSimulatorAdapter",
      "createMqttAdapter",
      "createIrrigationHttpV1Adapter"
    ],
    "negative_checks": [
      {
        "case": "missing_adapter_type",
        "source_token": "ADAPTER_TYPE_REQUIRED"
      },
      {
        "case": "duplicate_adapter_type",
        "source_token": "ADAPTER_ALREADY_REGISTERED"
      },
      {
        "case": "unknown_adapter_type",
        "source_token": "ADAPTER_NOT_FOUND"
      }
    ]
  },
  "runtime_dispatch_guard": {
    "source_file": "apps/executor/src/run_dispatch_once.ts",
    "negative_checks": [
      {
        "case": "unsupported_action_type",
        "source_token": "ADAPTER_UNSUPPORTED_ACTION"
      },
      {
        "case": "adapter_validate_failed",
        "source_token": "ADAPTER_VALIDATE_FAILED"
      }
    ]
  },
  "adapters": [
    {
      "adapter_type": "irrigation_real",
      "factory": "createIrrigationRealAdapter",
      "source_file": "apps/executor/src/adapters/irrigation_real_adapter.ts",
      "capabilities": [
        "irrigation.downlink.record"
      ],
      "supported_action_types": [
        "irrigate",
        "irrigation.start"
      ],
      "support_input": "string_or_task",
      "required_task_fields": [
        "outbox_fact_id",
        "device_id"
      ],
      "required_runtime_context": [
        "baseUrl",
        "token"
      ],
      "negative_checks": [
        {
          "case": "missing_outbox_fact_id",
          "source_token": "MISSING_OUTBOX_FACT_ID"
        },
        {
          "case": "missing_device_id",
          "source_token": "MISSING_DEVICE_ID"
        },
        {
          "case": "device_capability_missing_irrigation",
          "source_token": "DEVICE_CAPABILITY_MISSING_IRRIGATION"
        }
      ],
      "live_effect_boundary": "records a server-side published downlink fact; this manifest does not authorize physical actuation"
    },
    {
      "adapter_type": "irrigation_simulator",
      "factory": "createIrrigationSimulatorAdapter",
      "source_file": "apps/executor/src/adapters/irrigation_simulator.ts",
      "capabilities": [
        "irrigation.simulated_downlink",
        "fertilize.simulated_receipt"
      ],
      "supported_action_types": [
        "irrigate",
        "irrigation.start",
        "FERTILIZE"
      ],
      "support_input": "string_or_task",
      "required_task_fields": [
        "act_task_id",
        "command_id"
      ],
      "required_runtime_context": [
        "baseUrl",
        "token"
      ],
      "negative_checks": [
        {
          "case": "unsupported_action_type",
          "source_token": "UNSUPPORTED_ACTION"
        },
        {
          "case": "missing_act_task_id",
          "source_token": "MISSING_ACT_TASK_ID"
        },
        {
          "case": "missing_command_id",
          "source_token": "MISSING_COMMAND_ID"
        }
      ],
      "live_effect_boundary": "simulator only; no physical actuation"
    },
    {
      "adapter_type": "mqtt",
      "factory": "createMqttAdapter",
      "source_file": "apps/executor/src/adapters/mqtt.ts",
      "capabilities": [
        "mqtt.downlink.publish",
        "downlink.fact.record"
      ],
      "supported_action_types": [
        "adapter_type:mqtt"
      ],
      "support_input": "string_or_task",
      "required_task_fields": [
        "outbox_fact_id",
        "device_id_or_topic"
      ],
      "required_runtime_context": [
        "baseUrl",
        "token"
      ],
      "negative_checks": [
        {
          "case": "missing_outbox_fact_id",
          "source_token": "MISSING_OUTBOX_FACT_ID"
        },
        {
          "case": "missing_topic",
          "source_token": "MISSING_TOPIC"
        },
        {
          "case": "publish_failed",
          "source_token": "PUBLISH_FAILED"
        }
      ],
      "live_effect_boundary": "publishes only when an operator-controlled runtime invokes it; this manifest does not connect to a broker"
    },
    {
      "adapter_type": "irrigation_http_v1",
      "factory": "createIrrigationHttpV1Adapter",
      "source_file": "apps/executor/src/adapters/irrigation_http_v1.ts",
      "capabilities": [
        "irrigation.http.command"
      ],
      "supported_action_types": [
        "irrigate",
        "irrigation.start"
      ],
      "support_input": "string_or_task",
      "required_task_fields": [
        "device_id",
        "operation_plan_id"
      ],
      "required_runtime_context": [
        "baseUrl",
        "token"
      ],
      "negative_checks": [
        {
          "case": "missing_device_id",
          "source_token": "MISSING_DEVICE_ID"
        },
        {
          "case": "missing_operation_plan_id",
          "source_token": "MISSING_OPERATION_PLAN_ID"
        },
        {
          "case": "http_error",
          "source_token": "HTTP_ERROR"
        }
      ],
      "live_effect_boundary": "HTTP command path remains non-authorized for pilot until P2-03 sandbox harness acceptance passes"
    }
  ],
  "next_step": "P2_03_SAFE_REAL_ADAPTER_SANDBOX_HARNESS"
}
