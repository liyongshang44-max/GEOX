{
  "schema_version": "acceptance_result_payload_schema_v0",
  "target_fact_type": "acceptance_result_v1",
  "persisted_verdict_allowed_values": ["PASS", "FAIL", "PARTIAL", "NEEDS_REVIEW", "INSUFFICIENT_EVIDENCE"],
  "PENDING_is_not_persisted_acceptance_result_v1_verdict": true,
