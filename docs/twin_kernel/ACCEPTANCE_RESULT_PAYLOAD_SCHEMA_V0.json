  "required_fields": ["tenant_id", "project_id", "group_id", "operation_plan_id", "act_task_id", "receipt_fact_id", "operation_plan_transition_fact_id", "operation_plan_fact_id", "acceptance_id", "verdict", "formal_acceptance", "formal_evidence_passed", "source_lane", "customer_visible_eligible", "evidence_refs", "missing_evidence", "blocking_reasons", "reviewer_ref", "reviewed_at_ts", "meta.source_refs", "meta.policy_refs", "meta.idempotency_key"],
  "PASS_requires_formal_acceptance": true,
  "PASS_requires_formal_evidence_passed": true,
  "PASS_requires_customer_visible_eligible": true,
  "FAIL_requires_formal_acceptance": true,
  "FAIL_requires_formal_evidence_passed": true,
  "FAIL_requires_customer_visible_eligible": true,
  "PARTIAL_may_be_non_formal": true,
  "NEEDS_REVIEW_may_be_non_formal": true,
  "INSUFFICIENT_EVIDENCE_may_be_non_formal": true,
  "technical_receipt_is_not_formal_acceptance": true,
  "operation_plan_terminal_status_is_not_formal_acceptance": true,
  "effect_snapshot_is_not_formal_acceptance": true,
  "actual_effect_is_not_formal_acceptance": true,
  "fallback_acceptance_is_not_formal_acceptance": true
