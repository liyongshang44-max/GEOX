{
  "schema_version": "roi_ledger_payload_schema_v0",
  "target_fact_type": "roi_ledger_v1",
  "required_fields": [
    "tenant_id",
    "project_id",
    "group_id",
    "operation_plan_id",
    "act_task_id",
    "roi_ledger_id",
    "roi_boundary_fact_id",
    "roi_boundary_id",
    "outcome_review_fact_id",
    "acceptance_result_fact_id",
    "ledger_state",
    "accounting_window",
    "cost_basis_refs",
    "value_basis_refs",
    "accounting_policy_ref",
    "accounting_summary",
    "accounting_uncertainty_notes",
    "blocking_reasons",
    "reviewer_ref",
    "reviewed_at_ts",
    "meta.source_refs",
    "meta.policy_refs",
    "meta.idempotency_key"
  ],
  "allowed_ledger_states": [
    "RECORDED",
    "INSUFFICIENT_COST_BASIS",
    "INSUFFICIENT_VALUE_BASIS",
    "INSUFFICIENT_ACCOUNTING_POLICY",
    "POLICY_BLOCKED"
  ],
  "allowed_accounting_classification": [
    "FAVORABLE_ACCOUNTING_DELTA",
    "UNFAVORABLE_ACCOUNTING_DELTA",
    "NEUTRAL_ACCOUNTING_DELTA",
    "UNKNOWN_ACCOUNTING_DELTA",
    "POLICY_BLOCKED"
  ],
  "accounting_summary_is_accounting_snapshot_only": true,
  "accounting_summary_is_not_financial_claim": true,
  "accounting_summary_is_not_profit_realization": true,
  "accounting_summary_is_not_yield_attribution": true,
  "accounting_summary_is_not_effect_attribution": true,
  "accounting_summary_is_not_field_memory_input": true,
  "ledger_state_RECORDED_requires_complete_accounting_basis": true,
  "ledger_state_RECORDED_requires_cost_basis_refs": true,
  "ledger_state_RECORDED_requires_value_basis_refs": true,
  "ledger_state_RECORDED_requires_accounting_policy_ref": true,
  "ledger_state_INSUFFICIENT_COST_BASIS_may_create_non_recorded_ledger_review": true,
  "ledger_state_INSUFFICIENT_VALUE_BASIS_may_create_non_recorded_ledger_review": true,
  "ledger_state_INSUFFICIENT_ACCOUNTING_POLICY_may_create_non_recorded_ledger_review": true,
  "INSUFFICIENT_COST_BASIS_is_not_roi_ledger_success": true,
  "INSUFFICIENT_VALUE_BASIS_is_not_roi_ledger_success": true,
  "POLICY_BLOCKED_is_not_roi_ledger_success": true
}
